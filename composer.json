{
    "name": "company/inventory-sales-system",
    "description": "Inventory & Sales Management System built on Yii2 Basic template",
    "keywords": ["yii2", "inventory", "sales", "rbac"],
    "type": "project",
    "require": {
        "php": ">=7.4",
        "yiisoft/yii2": "~2.0.49",
        "yiisoft/yii2-bootstrap5": "~2.0.3",
        "mpdf/mpdf": "^8.2"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0"
    },
    "config": {
        "process-timeout": 1800,
        "fxp-asset": { "enabled": false },
        "allow-plugins": { "yiisoft/yii2-composer": true }
    },
    "extra": {
        "yii\\composer\\Installer::postCreateProject": {
            "setPermission": [
                { "runtime": "0777", "web/assets": "0777" }
            ]
        }
    }
}
